{
  "name": "yiurblog",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "npm run build:ssg",
    "build:spa": "cross-env NODE_OPTIONS=\"--no-warnings\" valaxy build",
    "build:ssg": "cross-env NODE_OPTIONS=\"--no-warnings\" valaxy build --ssg",
    "dev": "cross-env NODE_OPTIONS=\"--no-warnings\" valaxy",
    "rss": "cross-env NODE_OPTIONS=\"--no-warnings\" valaxy rss",
    "serve": "cross-env NODE_OPTIONS=\"--no-warnings\" vite preview"
  },
  "dependencies": {
    "valaxy": "0.28.4",
    "valaxy-theme-yun": "0.28.4",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@unocss/reset": "^0.61.0",
    "@valaxyjs/utils": "0.28.4",
    "cross-env": "^10.1.0",
    "typescript": "^5.8.3",
    "valaxy-addon-algolia": "^0.2.1",
    "valaxy-addon-artalk": "^0.1.3",
    "valaxy-addon-bangumi": "^0.4.0",
    "valaxy-addon-twikoo": "^0.0.3",
    "valaxy-addon-waline": "^0.2.1",
    "vite": "^6.0.0"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "vue-demi"
    ],
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild"
    ]
  }
}